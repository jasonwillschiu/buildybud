# Canonical site URL used to expand relative purge paths
BB_APP_BASE_URL=https://example.com

# Optional default CDN provider for buildybud cdn commands: bunny or cloudflare
BB_CDN_PROVIDER=cloudflare

# Optional explicit purge hosts. Defaults to BB_APP_BASE_URL host and inferred apex/www pair.
# BB_CDN_PURGE_HOSTS=example.com,www.example.com

# Bunny provider credentials
# BB_BUNNY_API_KEY=

# Cloudflare provider credentials
# BB_CF_API_TOKEN=
# BB_CF_ZONE_ID=
